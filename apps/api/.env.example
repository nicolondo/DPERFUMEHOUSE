# ─── App ───────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
APP_URL=http://localhost:3001
SELLER_APP_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3002

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dperfumehouse?schema=public

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-secret-at-least-32-chars

# ─── Odoo ──────────────────────────────────────────────
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_odoo_db
ODOO_UID=2
ODOO_API_KEY=your_odoo_api_key

# ─── MyxSpend Payment Gateway ─────────────────────────
MYXSPEND_EMAIL=your@email.com
MYXSPEND_PASSWORD=your_password
MYXSPEND_BASE_URL=https://api.myxspend.com/v1
MYXSPEND_POSTBACK_URL=https://your-api.com/payments/webhook
MYXSPEND_API_KEY=obtained-from-login

# ─── Email ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your_app_password
MAIL_FROM="D Perfume House <noreply@dperfumehouse.com>"
ORDERS_EMAIL=ordenes@dperfumehouse.com

# ─── Storage ───────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ─── AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Envia Shipping ───────────────────────────────────
ENVIA_API_KEY=
ENVIA_BASE_URL=https://api.envia.com
ENVIA_QUERIES_URL=https://queries.envia.com

# ─── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=
