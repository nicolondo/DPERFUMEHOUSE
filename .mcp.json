{
  "mcpServers": {
    "ruflo": {
      "command": "npx",
      "args": [
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "RUFLO_MODE": "v3",
        "RUFLO_HOOKS_ENABLED": "true",
        "RUFLO_TOPOLOGY": "hierarchical-mesh",
        "RUFLO_MAX_AGENTS": "15",
        "RUFLO_MEMORY_BACKEND": "hybrid",
        "RUFLO_PROJECT": "dperfumehouse"
      },
      "autoStart": false
    }
  }
}